{
  "name": "avra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ready-check": "node ./scripts/ready-check.mjs",
    "clean": "node ./scripts/clean.mjs --mode=all",
    "clean:dev": "node ./scripts/clean.mjs --mode=dev",
    "clean:build": "node ./scripts/clean.mjs --mode=build",
    "predev": "npm run ready-check && npm run clean:dev",
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "prebuild": "npm run ready-check && npm run clean:build",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mistralai/mistralai": "^2.1.2",
    "@prisma/client": "^6.3.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@types/sanitize-html": "^2.16.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.0",
    "pdfjs-dist": "^5.5.207",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "sanitize-html": "^2.17.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.3.6"
