{
  "name": "assessly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ready-check": "node ./scripts/ready-check.mjs",
    "audit:verify-chain": "npx tsx scripts/verify-audit-chain.ts",
    "audit:tamper-test": "npx tsx scripts/forensic-tamper-test.ts",
    "audit:simulate-trace": "npx tsx scripts/simulate-traceability-chain.ts",
    "clean": "node ./scripts/clean.mjs --mode=all",
    "clean:dev": "node ./scripts/clean.mjs --mode=dev",
    "clean:build": "node ./scripts/clean.mjs --mode=build",
    "compute-themes-hash": "node ./scripts/compute-themes-hash.mjs",
    "env:validate": "node ./scripts/env-check.mjs",
    "predev": "npm run ready-check && npm run clean:dev",
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "prebuild": "npm run ready-check && npm run env:validate && npm run compute-themes-hash && npm run clean:build",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate && node ./scripts/compute-themes-hash.mjs",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.744.0",
    "@hookform/resolvers": "^5.2.2",
    "@mistralai/mistralai": "^2.1.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@types/sanitize-html": "^2.16.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "lucide-react": "^1.7.0",
    "next": "^15.1.0",
    "next-intl": "^4.8.4",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "openid-client": "^6.8.2",
    "otplib": "^13.4.0",
    "pdfjs-dist": "^5.6.205",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "sanitize-html": "^2.17.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.10.0",
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^6.19.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.16",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "prisma": {
    "seed": "./node_modules/.bin/tsx prisma/seed.ts"
  }
}
