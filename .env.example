# Local development (SQLite). For production EU deployments, use PostgreSQL in an EU region, e.g.:
# DATABASE_URL="postgresql://user:pass@eu-central-1.rds.amazonaws.com:5432/avra?schema=public"
DATABASE_URL="file:./prisma/dev.db"

# AI Provider Configuration
# Set to 'local' for on-premise execution or 'mistral' for external EU API.
AI_PROVIDER="local"
AI_API_KEY="your_mistral_api_key_here"
AI_ENDPOINT="http://localhost:11434/v1" # e.g., for Ollama local endpoints
