# PostgreSQL connection string format:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local docker example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/avra?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# AI Provider Configuration
# Set to 'local' for on-premise execution or 'mistral' for external EU API.
AI_PROVIDER="local"
MISTRAL_API_KEY="your_mistral_api_key_here"
LOCAL_AI_ENDPOINT="http://localhost:11434/v1"
LOCAL_AI_MODEL="mistral"

# ── Email Configuration ───────────────────────────────────────────────────────
# MAIL_STRATEGY controls which transport is used.
#   log    → Simulates delivery to the console (default; no config needed).
#   smtp   → Standard SMTP — works with Gmail, Outlook, private relays, Postmark SMTP.
#   resend → Resend API (https://resend.com) — recommended for serverless/edge.
#
# Set MAIL_FROM to the display name + address your recipients will see.
# The domain must be verified with your chosen provider.
#
MAIL_STRATEGY="log"
MAIL_FROM="AVRA Compliance <noreply@yourdomain.com>"
# Display name used inside email templates (e.g. in greetings and footer).
MAIL_COMPANY_NAME="AVRA Compliance"

# SMTP settings (required when MAIL_STRATEGY=smtp)
SMTP_HOST="smtp.yourdomain.com"
SMTP_PORT="587"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASSWORD="your_smtp_password_here"

# Resend API key (required when MAIL_STRATEGY=resend)
# Get yours at https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"
