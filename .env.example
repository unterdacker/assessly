# =============================================================================
# Venshield — Sovereign Vendor Risk Assessment Platform
# Environment Variable Reference
# Copy this file to .env and fill in ALL required values before running.
# NEVER commit .env to version control — add it to .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# NEXT.JS SERVER ACTIONS (required for stable dev & multi-instance prod)
# -----------------------------------------------------------------------------
# Stable encryption key for server action IDs. Prevents "Server Action not found"
# errors caused by key rotation across dev server restarts or multiple instances.
# Must be base64-encoded, 32 bytes (AES-256).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="CHANGE_ME"

# -----------------------------------------------------------------------------
# DATABASE (required)
# -----------------------------------------------------------------------------

# PostgreSQL connection string format:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local docker example:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/venshield?schema=public"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"


# -----------------------------------------------------------------------------
# SESSION & AUTHENTICATION (required in production)
# -----------------------------------------------------------------------------

# HMAC-SHA256 key used to sign and verify session tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: using the default or a weak key allows forging session tokens.
AUTH_SESSION_SECRET="CHANGE_ME"

# Legacy alias — AUTH_SESSION_SECRET takes precedence when both are set.
# NEXTAUTH_SECRET="CHANGE_ME"


# -----------------------------------------------------------------------------
# SETTINGS ENCRYPTION (required in production)
# -----------------------------------------------------------------------------

# AES-256-GCM key for encrypting sensitive settings at rest (API keys, SMTP passwords).
# Must be exactly 64 hex characters (32 bytes / 256 bits).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_ENCRYPTION_KEY="CHANGE_ME"

# AES-256-GCM key for encrypting TOTP / MFA secrets.
# Must be exactly 64 hex characters (32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY="CHANGE_ME"


# -----------------------------------------------------------------------------
# APPLICATION URL (required)
# -----------------------------------------------------------------------------

# Public base URL — used to build invite links, portal redirects, and cookie domains.
# No trailing slash.
NEXT_PUBLIC_APP_URL="https://venshield.example.com"


# -----------------------------------------------------------------------------
# SERVER-SIDE APP URL (required in all environments)
# -----------------------------------------------------------------------------

# Internal server-side base URL — used for OIDC callbacks, server-to-server
# requests, and redirect validation. Must exactly match your public URL.
# In production: must be https://. No trailing slash.
# Generate: use the same value as NEXT_PUBLIC_APP_URL.
APP_URL="http://localhost:3000"


# -----------------------------------------------------------------------------
# OIDC STATE SECRET (required in all environments — even without SSO)
# -----------------------------------------------------------------------------

# HMAC-SHA256 signing key for the OIDC state parameter cookie.
# Prevents CSRF attacks on SSO callbacks. Required even if SSO is not configured.
# Must be at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OIDC_STATE_SECRET="CHANGE_ME"


# -----------------------------------------------------------------------------
# STORAGE ENCRYPTION (required in production)
# -----------------------------------------------------------------------------

# AES-256-GCM key for encrypting uploaded PDF evidence files at rest
# in the .venshield-storage/ directory.
# Must be exactly 64 hex characters (32 bytes / 256 bits).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STORAGE_ENCRYPTION_KEY="CHANGE_ME"


# -----------------------------------------------------------------------------
# CRON JOB SECURITY (required — endpoint denies ALL requests when unset)
# -----------------------------------------------------------------------------

# Bearer token for authenticating scheduled job calls to /api/cron/*.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="CHANGE_ME"


# -----------------------------------------------------------------------------
# AI PROVIDER (optional — can also be configured via the Settings UI)
# -----------------------------------------------------------------------------

# Set to 'local' for on-premise execution or 'mistral' for external EU API.
AI_PROVIDER="local"

# Mistral AI API key (used when AI_PROVIDER=mistral).
# If set here it takes precedence over the encrypted DB value.
MISTRAL_API_KEY="your_mistral_api_key_here"

# Local LLM base URL (used when AI_PROVIDER=local, e.g. Ollama).
# SSRF note: keep this pointing to a loopback or trusted internal address.
LOCAL_AI_ENDPOINT="http://localhost:11434"
LOCAL_AI_MODEL="ministral-3:8b"


# -----------------------------------------------------------------------------
# MAIL (optional — defaults to LOG strategy which prints to stdout)
# -----------------------------------------------------------------------------

# MAIL_STRATEGY controls which transport is used:
#   log     → Simulates delivery to the console (default; no config required).
#   smtp    → Standard SMTP relay (SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD).
#   resend  → Resend SaaS API (RESEND_API_KEY) — recommended for serverless/edge.
#   mailpit → Local Mailpit SMTP trap (dev only; BLOCKED at runtime in production).
#             "mailhog" is a supported alias for "mailpit" (backward compat).
#
# Quickstart for local dev with Mailpit:
#   1. docker compose up mailpit
#   2. Set MAIL_STRATEGY=mailpit below (already set in this example file).
#   3. Open http://localhost:8025 to see captured emails.
#   4. If the DB already has a different mailStrategy from the web UI, also set
#      MAIL_FORCE_ENV=true (see below) to bypass the DB for this dev session.
MAIL_STRATEGY="mailpit"

# Sender address visible to email recipients — domain must be verified with provider.
MAIL_FROM="Venshield <noreply@yourdomain.com>"

# Display name used inside email templates (e.g. greetings and footer).
MAIL_COMPANY_NAME="Venshield"

# ── SMTP settings (required when MAIL_STRATEGY=smtp) ─────────────────────────
SMTP_HOST="smtp.yourdomain.com"
SMTP_PORT="587"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASSWORD="your_smtp_password_here"

# ── Resend (required when MAIL_STRATEGY=resend) ───────────────────────────────
# Get yours at https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"

# ── Mailpit local dev SMTP trap (used when MAIL_STRATEGY=mailpit or mailhog) ──
# Start: docker compose up mailpit
# Web UI: http://localhost:8025  |  SMTP: localhost:1025
# WARNING: inbox is EPHEMERAL — all messages are lost on container restart.
# NEVER use MAIL_STRATEGY=mailpit in production — it is BLOCKED at startup.
#
# MAILPIT_SMTP_HOST defaults to "localhost" for direct dev (npm run dev).
# Docker Compose automatically injects MAILPIT_SMTP_HOST=venshield-mailpit so
# the app container can reach Mailpit by service name — no manual change needed.
#
# Value must be a plain hostname (no http:// prefix).
MAILPIT_SMTP_HOST="localhost"
MAILPIT_SMTP_PORT="1025"
# Backward-compat aliases (kept for existing .env files; can be removed in new setups):
# MAILHOG_SMTP_HOST="localhost"
# MAILHOG_SMTP_PORT="1025"

# ── MAIL_FORCE_ENV escape hatch ───────────────────────────────────────────────
# When set to "true", lib/mail.ts skips the DB lookup and reads all mail
# settings from the env vars above. Use this when the DB already has a different
# mailStrategy stored from a previous Admin › Settings › Mail session, and you
# want to test Mailpit locally without resetting the database.
#
# SECURITY: This override is BLOCKED in production by env.ts (startup fatal
# error). However, the guard only fires when NODE_ENV=production — ensure your
# deployment environment always sets NODE_ENV=production to keep this protected.
# NEVER set MAIL_FORCE_ENV=true in a production .env file.
MAIL_FORCE_ENV="false"


# -----------------------------------------------------------------------------
# AUDIT LOG SECURITY (required in production)
# -----------------------------------------------------------------------------

# HMAC key for pseudonymising user IDs in exported audit bundles (GDPR Art. 5).
# Required in production — must be at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUDIT_EXPORT_KEY="CHANGE_ME"

# HMAC key for pseudonymising user IDs in exported audit reports (GDPR Art. 4(5)).
# Required in production — must be at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUDIT_PSEUDONYMIZATION_KEY="CHANGE_ME"

# HMAC signing key for forensic audit bundle integrity and downloads.
# Also referred to as the "audit signing secret" (AUDIT_SIGNING_SECRET) in security docs.
# Required in production — must be at least 32 characters, no placeholder.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUDIT_BUNDLE_SECRET="CHANGE_ME"


# -----------------------------------------------------------------------------
# SEED / INITIAL ADMIN (development / CI only — NEVER set in production)
# -----------------------------------------------------------------------------

# VENSHIELD_ADMIN_EMAIL="admin@venshield.local"
# VENSHIELD_ADMIN_PASSWORD="change-me-strong-password"
# VENSHIELD_AUDITOR_EMAIL="auditor@venshield.local"
# VENSHIELD_AUDITOR_PASSWORD="change-me-strong-password"


# -----------------------------------------------------------------------------
# NODE ENVIRONMENT
# -----------------------------------------------------------------------------

# NODE_ENV="production"
NODE_ENV="development"
