// Venshield — EU-oriented multi-tenant core.
// PostgreSQL is the default provider for local and production environments.

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssessmentStatus {
  PENDING
  UNDER_REVIEW
  SUBMITTED
  REVIEWER_APPROVED
  SIGN_OFF
  COMPLETED
  REJECTED
  ARCHIVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum UserRole {
  ADMIN
  RISK_REVIEWER
  AUDITOR
  VENDOR
}

enum MailStrategy {
  SMTP
  RESEND
  LOG
}

enum CompanyPlan {
  FREE
  PREMIUM
}

enum RemediationTaskStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  WONT_FIX
}

enum ExecReportStatus {
  DRAFT
  FINALIZED
}

enum QuestionType {
  TEXT
  SINGLE_CHOICE
  MULTI_CHOICE
  SCALE
  BOOLEAN
  FILE_UPLOAD
}

enum ReminderType {
  PRE_DUE
  OVERDUE
  ESCALATION
  MANUAL
}

enum RecurrenceInterval {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

model Company {
  id                 String      @id @default(cuid())
  name               String
  slug               String      @unique
  aiProvider         String      @default("local")
  aiDisabled         Boolean     @default(true)
  mistralApiKey      String?
  localAiEndpoint    String?     @default("http://localhost:11434")
  localAiModel       String?     @default("ministral-3:8b")
  lastAiSummary      String?
  aiSummaryUpdatedAt DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  createdBy          String
  plan               CompanyPlan @default(FREE)
  mfaRequired        Boolean     @default(false)

  vendors                  Vendor[]
  assessments              Assessment[]
  auditLogs                AuditLog[]
  customVendorServiceTypes CustomVendorServiceType[]
  users                    User[]
  oidcConfig               OidcConfig?
  execReports              ExecReport[]
  customQuestions          Question[]
  remediationTasks         RemediationTask[]
  webhooks                 Webhook[]
  apiKeys                  ApiKey[]
  questionnaireTemplates   QuestionnaireTemplate[]
  slaPolicies              SlaPolicy[]
  recurrenceSchedules      RecurrenceSchedule[]
  complianceSnapshots      ComplianceSnapshot[]
}

model OidcConfig {
  id                     String   @id @default(cuid())
  companyId              String   @unique
  company                Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  issuerUrl              String
  clientId               String
  clientSecretEncrypted  String
  isEnabled              Boolean  @default(false)
  jitProvisioning        Boolean  @default(false)
  jitAllowedEmailDomains String[] @default([])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([companyId])
}

/// Premium feature — implementation in modules/webhooks/
model Webhook {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  url             String
  secretEncrypted String
  events          String[] @default([])
  isEnabled       Boolean  @default(true)
  createdByUserId String?
  createdBy       User?    @relation("WebhookCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, isEnabled])
}

model User {
  id                 String    @id @default(cuid())
  companyId          String?
  company            Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  vendorId           String?   @unique
  vendor             Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  email              String?   @unique
  displayName        String?
  passwordHash       String?
  ssoProviderId      String?
  role               UserRole  @default(VENDOR)
  isActive           Boolean   @default(true)
  mfaEnabled         Boolean   @default(false)
  mfaSecret          String? // AES-256-GCM encrypted TOTP secret
  mfaRecoveryCodes   String[]  @default([])
  mfaEnforced        Boolean   @default(false)
  /// SHA-256 hash of the 32-byte random one-time invite token for initial password setup.
  inviteToken        String?   @unique
  /// Expiry for the user invite token (48 hours from invite creation).
  inviteTokenExpires DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          String

  sessions                      AuthSession[]
  execReports                   ExecReport[]
  assignedRemediationTasks      RemediationTask[]       @relation("AssignedRemediationTasks")
  createdWebhooks               Webhook[]               @relation("WebhookCreatedBy")
  createdQuestionnaireTemplates QuestionnaireTemplate[] @relation("TemplateCreatedBy")
  createdApiKeys                ApiKey[]                @relation("ApiKeyCreatedBy")
  reviewedAssessments           Assessment[]            @relation("AssessmentReviewer")
  createdRecurrenceSchedules    RecurrenceSchedule[]    @relation("RecurrenceScheduleCreatedBy")
  assessmentApprovalSteps       AssessmentApprovalStep[] @relation("ApprovalStepActor")
  escalationSlaPolicies         SlaPolicy[]             @relation("SlaEscalationRecipient")

  @@unique([companyId, ssoProviderId])
  @@index([companyId])
  @@index([role])
}

model AuthSession {
  id         String    @id
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId  String?
  vendorId   String?
  role       UserRole
  tokenHash  String    @unique
  expiresAt  DateTime
  lastSeenAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String

  @@index([userId])
  @@index([companyId])
  @@index([vendorId])
  @@index([role])
  @@index([expiresAt])
  @@index([userId, expiresAt])
}

model Vendor {
  id                      String    @id @default(cuid())
  companyId               String
  company                 Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                    String
  email                   String
  serviceType             String
  // NIS2-relevant metadata
  officialName            String?
  registrationId          String?
  vendorServiceType       String?
  vendorServiceTypeCustom String?
  securityOfficerName     String?
  securityOfficerEmail    String?
  dpoName                 String?
  dpoEmail                String?
  headquartersLocation    String?
  sizeClassification      String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  createdBy               String
  accessCode              String?   @unique
  codeExpiresAt           DateTime?
  isCodeActive            Boolean   @default(false)
  passwordHash            String?
  isFirstLogin            Boolean   @default(true)
  inviteSentAt            DateTime?
  inviteToken             String?   @unique
  inviteTokenExpires      DateTime?
  /// SHA-256 hash of the 32-byte random one-time setup token (plaintext never stored).
  setupToken              String?   @unique
  /// Expiry for the one-time setup token (48 hours from access code generation).
  setupTokenExpires   DateTime?

  assessment         Assessment?
  user               User?
  recurrenceSchedule RecurrenceSchedule?

  @@index([companyId])
}

/// One current assessment row per vendor (latest lifecycle).
model Assessment {
  id                 String           @id @default(cuid())
  companyId          String
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendorId           String           @unique
  vendor             Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  status             AssessmentStatus @default(PENDING)
  riskLevel          RiskLevel
  complianceScore    Int
  lastAssessmentDate DateTime?
  documentFilename   String?
  documentUrl        String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  createdBy          String

  dueDate          DateTime?
  slaPolicyId      String?
  slaPolicy        SlaPolicy?               @relation(fields: [slaPolicyId], references: [id], onDelete: SetNull)
  slaBreached      Boolean                  @default(false)
  answers          AssessmentAnswer[]
  documents        Document[]
  execReports      ExecReport[]
  approvalSteps    AssessmentApprovalStep[]
  reminders        AssessmentReminder[]
  reviewerUserId   String?
  reviewerUser     User?                    @relation("AssessmentReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  recurrenceSchedules RecurrenceSchedule[]  @relation("RecurrenceLastAssessment")
  remediationTasks RemediationTask[]

  @@index([companyId])
  @@index([vendorId])
  @@index([slaPolicyId])
  @@index([dueDate])
}

/// Approval workflow audit trail — each row records one state transition.
/// GDPR: actorUserId SET NULL on user deletion; comment nullified in deleteUser $transaction.
model AssessmentApprovalStep {
  id           String           @id @default(cuid())
  assessmentId String
  assessment   Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  fromStatus   AssessmentStatus
  toStatus     AssessmentStatus
  actorUserId  String?
  actorUser    User?            @relation("ApprovalStepActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  comment      String?
  createdAt    DateTime         @default(now())

  @@index([assessmentId])
  @@index([actorUserId])
}

model ExecReport {
  id           String     @id @default(cuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  creatorUserId String?
  creatorUser   User?   @relation(fields: [creatorUserId], references: [id], onDelete: SetNull)
  createdBy     String

  status ExecReportStatus @default(DRAFT)

  executiveSummary   String?
  remediationRoadmap String?
  aiDraftSummary     String?
  aiDraftRoadmap     String?

  eventHash          String?
  previousReportHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([assessmentId])
  @@index([creatorUserId])
  @@index([status])
  @@index([companyId, status])
}

/// Global NIS2 question catalogue (seeded; version via NIS2_QUESTIONNAIRE_VERSION in app).
model Question {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  isCustom  Boolean  @default(false)
  category  String
  text      String
  guidance  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  @@index([category])
  @@index([companyId])
}

model AuditLog {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId        String   @default("system")
  action        String
  entityType    String
  entityId      String
  previousValue Json?
  newValue      Json?
  timestamp     DateTime @default(now())
  // Legacy fields kept temporarily to avoid breaking existing writes.
  actorId       String
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String
  // === Privacy-First Forensic Logging: Multi-Framework Compliance ===

  /// SOC2/ISO 27001/BSI: Framework category for compliance filtering.
  /// Values: AI_ACT | AUTH | CONFIG | NIS2_DORA | ISO27001_SOC2 | BSI_TISAX | OTHER
  complianceCategory String?

  /// GDPR Art. 5(1)(b) — Purpose limitation: documented intent for sensitive operations.
  reason String?

  /// GDPR retention tier applied at write-time. HIGH=security, LOW=operational telemetry.
  retentionPriority String?

  /// Calculated expiry timestamp for retention enforcement jobs.
  retentionUntil DateTime?

  /// GDPR legal basis tag for accountability (Art. 6).
  /// Values: LEGAL_OBLIGATION | LEGITIMATE_INTEREST
  legalBasis String?

  /// NIS2/DORA: Request correlation ID to join this event with server-side API logs.
  requestId String?

  /// NIS2/DORA hash-chain: SHA-256 of the previous log entry's eventHash in this company's chain.
  /// Enables detection of deleted or reordered records (BSI Grundschutz / DORA Art. 9).
  previousLogHash String?

  /// NIS2/DORA hash-chain: SHA-256 of this entry's canonical fields for tamper evidence.
  eventHash String?

  /// EU AI Act Art. 14: Model identifier (e.g. "mistral-large-latest") for AI traceability.
  aiModelId String?

  /// EU AI Act Art. 14: Provider name (e.g. "mistral", "local") for AI traceability.
  aiProviderName String?

  /// EU AI Act Art. 12: SHA-256 hash of the AI prompt/source document.
  /// PII is never stored — only the hash, enabling integrity verification without data exposure.
  inputContextHash String?

  /// EU AI Act Art. 14 (HITL): ID of the human who reviewed and approved the AI output.
  /// Mandatory for Art. 14 compliance — proves human-in-the-loop oversight.
  hitlVerifiedBy String?

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([timestamp])
  @@index([complianceCategory])
  @@index([requestId])
  @@index([retentionUntil])
}

model AssessmentAnswer {
  id                String     @id @default(cuid())
  assessmentId      String
  assessment        Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId        String
  status            String
  findings          String?
  /// Vendor- or AI-provided justification text shown in the questionnaire textarea.
  justificationText String?
  evidenceSnippet   String?
  /// Internal storage key/URL for per-question uploaded evidence.
  evidenceFileUrl   String?
  /// Sanitized original filename shown back to the user.
  evidenceFileName  String?
  /// Whether this answer was auto-populated by AI (requires confirmation).
  isAiSuggested     Boolean    @default(false)
  /// Whether the AI suggestion has been verified by a human auditor.
  verified          Boolean    @default(false)
  /// Optional link to a stored Document record (per-answer supplemental evidence).
  documentId        String?
  document          Document?  @relation(fields: [documentId], references: [id])
  /// The status string suggested by AI ("COMPLIANT" or "NON_COMPLIANT").
  aiSuggestedStatus String?
  /// The internal confidence score assigned by the AI (0.0 to 1.0).
  aiConfidence      Float?
  /// The AI's internal reasoning or evidence trace (for audit purposes).
  aiReasoning       String?
  /// Free-text justification written by ISB when manually overriding an AI answer.
  manualNotes       String?
  /// URL of supplemental evidence PDF uploaded alongside a manual override.
  evidenceUrl       String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  createdBy         String

  @@index([assessmentId, questionId])
}

/// Custom vendor service types created by users for their company.
model CustomVendorServiceType {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  createdBy String

  @@unique([companyId, name])
  @@index([companyId])
}

/// Permanent PDF evidence records — append-only, never deleted.
/// Each upload is recorded here for audit-grade traceability under NIS2 Article 21.
model Document {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  /// Original filename as provided by the uploader.
  filename     String
  /// Path relative to the .venshield-storage/ root on the server.
  storagePath  String
  mimeType     String     @default("application/pdf")
  fileSize     Int
  uploadedAt   DateTime   @default(now())
  uploadedBy   String     @default("system")

  assessmentAnswers AssessmentAnswer[]

  @@index([assessmentId])
}

/// Singleton row (id = "singleton") holding system-wide configuration.
/// Sensitive fields (smtpPassword, resendApiKey) are stored AES-256-GCM encrypted.
model SystemSettings {
  id           String       @id @default("singleton")
  /// Mail delivery strategy; overrides MAIL_STRATEGY env var when set.
  mailStrategy MailStrategy @default(LOG)
  /// Sender address, e.g. "noreply@company.com".
  mailFrom     String?
  /// Sender display name, e.g. "Venshield".
  mailFromName String?
  /// SMTP relay host.
  smtpHost     String?
  /// SMTP port (default 587).
  smtpPort     Int?         @default(587)
  /// SMTP authentication username.
  smtpUser     String?
  /// SMTP password — AES-256-GCM encrypted via lib/crypto.ts.
  smtpPassword String?
  /// Resend API key — AES-256-GCM encrypted via lib/crypto.ts.
  resendApiKey String?
  updatedAt    DateTime     @updatedAt
  updatedBy    String?
}

model RemediationTask {
  id             String                @id @default(cuid())
  companyId      String
  assessmentId   String
  questionId     String
  title          String
  description    String?
  status         RemediationTaskStatus @default(OPEN)
  dueDate        DateTime?
  assigneeUserId String?
  resolvedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  createdBy      String

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assignee   User?      @relation("AssignedRemediationTasks", fields: [assigneeUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([assessmentId])
  @@index([assigneeUserId])
  @@index([companyId, status])
}

/// Premium feature - management UI in modules/api-keys/
model ApiKey {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  /// SHA-256 hex digest of the raw key. Only used for constant-time verification. Never logged or returned.
  keyHash         String    @unique
  /// First 8 hex chars after "vs_live_" prefix - displayed in UI to identify the key.
  keyPrefix       String
  scopes          String[]  @default([])
  isActive        Boolean   @default(true)
  usageCount      Int       @default(0)
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  createdByUserId String?
  createdBy       User?     @relation("ApiKeyCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  usageLogs ApiKeyUsageLog[]

  @@index([companyId])
  @@index([companyId, isActive])
}

model ApiKeyUsageLog {
  id             String   @id @default(cuid())
  apiKeyId       String
  apiKey         ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  endpoint       String
  method         String
  statusCode     Int
  requestedAt    DateTime @default(now())
  /// GDPR storage limitation: calculated at write time (90 days from requestedAt).
  retentionUntil DateTime

  @@index([apiKeyId])
  @@index([requestedAt])
  @@index([retentionUntil])
}

/// Premium feature — implementation in modules/questionnaire-builder/
model QuestionnaireTemplate {
  id                   String                @id @default(cuid())
  companyId            String
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                 String
  description          String?
  systemTemplateKey    String?
  frameworkCategory    String?
  isActive             Boolean               @default(true)
  createdByUserId      String?
  createdBy            User?                 @relation("TemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  sections             TemplateSection[]
  recurrenceSchedules  RecurrenceSchedule[]

  @@unique([companyId, systemTemplateKey])
  @@index([companyId])
  @@index([companyId, isActive])
}

model TemplateSection {
  id          String                @id @default(cuid())
  templateId  String
  template    QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title       String
  description String?
  orderIndex  Int
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  questions   TemplateQuestion[]

  @@index([templateId])
  @@index([templateId, orderIndex])
}

model TemplateQuestion {
  id         String          @id @default(cuid())
  sectionId  String
  section    TemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  text       String
  helpText   String?
  type       QuestionType
  isRequired Boolean         @default(false)
  orderIndex Int
  options    Json?
  scaleMin   Int?
  scaleMax   Int?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([sectionId])
  @@index([sectionId, orderIndex])
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

/// Premium feature — implementation in modules/sla-tracking/
model SlaPolicy {
  id                        String    @id @default(cuid())
  companyId                 String
  company                   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                      String
  responseDays              Int
  reminderIntervals         Int[]     @default([])
  escalationDays            Int       @default(0)
  escalationRecipientUserId String?
  escalationRecipient       User?     @relation("SlaEscalationRecipient", fields: [escalationRecipientUserId], references: [id], onDelete: SetNull)
  isDefault                 Boolean   @default(false)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  assessments Assessment[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([escalationRecipientUserId])
}

/// SLA reminder log — one row per scheduled or sent reminder.
/// GDPR: recipientEmail is PII — 90-day purge scheduled.
model AssessmentReminder {
  id             String       @id @default(cuid())
  assessmentId   String
  assessment     Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  type           ReminderType
  recipientEmail String
  scheduledAt    DateTime
  sentAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([assessmentId])
  @@index([sentAt, scheduledAt])
}

/// Recurring assessment schedule per vendor. Tracks when next assessment is due.
model RecurrenceSchedule {
  id                  String                  @id @default(cuid())
  vendorId            String
  vendor              Vendor                  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  companyId           String
  company             Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  templateId          String?
  template            QuestionnaireTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  interval            RecurrenceInterval
  lastAssessmentId    String?
  lastAssessment      Assessment?             @relation("RecurrenceLastAssessment", fields: [lastAssessmentId], references: [id], onDelete: SetNull)
  nextDueAt           DateTime
  isActive            Boolean                 @default(true)
  autoSend            Boolean                 @default(false)
  regressionThreshold Int                     @default(10)
  createdByUserId     String?
  createdBy           User?                   @relation("RecurrenceScheduleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@unique([vendorId, companyId])
  @@index([companyId])
  @@index([nextDueAt])
  @@index([companyId, isActive])
}

/// NIS2 Art. 21 compliance record. Retain for 5 years. Anonymized (no PII).
/// categoryScores: Record<string, number> — aggregated numeric scores per category only.
model ComplianceSnapshot {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  snapshotDate   DateTime
  overallScore   Decimal  @db.Decimal(5, 2)
  categoryScores Json
  frameworkKey   String?
  vendorCount    Int
  createdAt      DateTime @default(now())

  @@index([companyId, snapshotDate])
}
